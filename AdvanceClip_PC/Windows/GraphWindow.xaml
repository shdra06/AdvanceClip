<mica:MicaWindow x:Class="AdvanceClip.Windows.GraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mica="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Graph Plotter" Height="520" Width="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize" MinWidth="400" MinHeight="350"
        Background="Transparent">

    <Grid>
        <!-- Header -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="#0AFFFFFF" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Grid.Column="0" Symbol="MathFormatLinear24" FontSize="20" Foreground="#A78BFA" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="EquationTitle" Text="y = x² - 4" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource MicaWPF.Brushes.TextFillColorPrimary}"/>
                    <TextBlock x:Name="ZoomLabel" Text="Zoom: 100%" FontSize="10" Foreground="{DynamicResource MicaWPF.Brushes.TextFillColorTertiary}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ui:Button Content="−" Appearance="Secondary" Padding="10,4" CornerRadius="8" Click="ZoomOut_Click" Margin="0,0,4,0" FontSize="16" FontWeight="Bold"/>
                    <ui:Button Content="⟳" Appearance="Secondary" Padding="10,4" CornerRadius="8" Click="ResetZoom_Click" Margin="0,0,4,0" FontSize="14"/>
                    <ui:Button Content="+" Appearance="Secondary" Padding="10,4" CornerRadius="8" Click="ZoomIn_Click" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Graph Canvas -->
        <Border Grid.Row="1" Background="#05FFFFFF" Margin="8" CornerRadius="12" ClipToBounds="True">
            <Canvas x:Name="GraphCanvas" Background="Transparent" 
                    MouseWheel="GraphCanvas_MouseWheel" 
                    MouseLeftButtonDown="GraphCanvas_MouseDown"
                    MouseLeftButtonUp="GraphCanvas_MouseUp"
                    MouseMove="GraphCanvas_MouseMove"
                    SizeChanged="GraphCanvas_SizeChanged"
                    Cursor="Cross"/>
        </Border>

        <!-- Coordinate Display -->
        <Border Grid.Row="2" Background="#08FFFFFF" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="CoordDisplay" Text="Move cursor over graph" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource MicaWPF.Brushes.TextFillColorTertiary}"/>
            </StackPanel>
        </Border>
    </Grid>
</mica:MicaWindow>
