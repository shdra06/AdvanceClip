<Window x:Class="AdvanceClip.Windows.PreviewPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preview" 
        SizeToContent="WidthAndHeight"
        MaxWidth="420" MaxHeight="320"
        WindowStyle="None" ResizeMode="NoResize" 
        Background="Transparent" AllowsTransparency="True"
        ShowInTaskbar="False" Topmost="True" Focusable="False"
        ShowActivated="False"
        MouseLeave="Window_MouseLeave">
    <Border CornerRadius="12" Padding="14" Margin="4"
            Background="#E6181A20" BorderBrush="#30FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.4" Color="Black"/>
        </Border.Effect>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      MaxHeight="280" MaxWidth="390">
            <TextBlock Name="PreviewText" 
                       Foreground="#E0E0E0" FontSize="12.5" FontFamily="Segoe UI"
                       TextWrapping="Wrap" LineHeight="18"/>
        </ScrollViewer>
    </Border>
</Window>
