<controls:MicaWindow x:Class="AdvanceClip.Windows.TimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Timer" Height="420" Width="360"
        WindowStartupLocation="CenterScreen"
        SystemBackdropType="Mica" Topmost="True"
        Background="Transparent" ResizeMode="NoResize">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" CornerRadius="12" GlassFrameThickness="-1" />
    </WindowChrome.WindowChrome>

    <Grid>
        <!-- Title bar drag region -->
        <Border Height="36" VerticalAlignment="Top" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <TextBlock Text="⏱ Timer" FontSize="12" FontWeight="SemiBold" Opacity="0.5" VerticalAlignment="Center" Margin="16,0,0,0"
                           Foreground="{DynamicResource MicaWPF.Brushes.TextFillColorSecondary}"/>
                <Button HorizontalAlignment="Right" Margin="0,0,4,0" Padding="8" Background="Transparent" BorderBrush="Transparent" Click="Close_Click" Cursor="Hand">
                    <TextBlock Text="✕" FontSize="12" Opacity="0.5" Foreground="{DynamicResource MicaWPF.Brushes.TextFillColorSecondary}"/>
                </Button>
            </Grid>
        </Border>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,16,0,0">
            <!-- Circular progress ring -->
            <Grid Width="220" Height="220" HorizontalAlignment="Center">
                <!-- Background track -->
                <Ellipse Width="220" Height="220" StrokeThickness="6" Stroke="#15FFFFFF" Fill="Transparent"/>
                
                <!-- Glow effect behind arc -->
                <Ellipse Name="GlowRing" Width="200" Height="200" StrokeThickness="0" Fill="Transparent" Opacity="0.15">
                    <Ellipse.Effect>
                        <BlurEffect Radius="30"/>
                    </Ellipse.Effect>
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8B5CF6" Offset="0"/>
                            <GradientStop Color="#3B82F6" Offset="0.5"/>
                            <GradientStop Color="#06B6D4" Offset="1"/>
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                </Ellipse>

                <!-- Progress arc (drawn in code-behind) -->
                <Canvas Name="ArcCanvas" Width="220" Height="220" ClipToBounds="False"/>
                
                <!-- Center content -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Main time display -->
                    <TextBlock Name="TimeDisplay" Text="05:00" FontSize="48" FontWeight="Bold" 
                               FontFamily="Segoe UI Variable, Segoe UI" TextAlignment="Center"
                               Foreground="{DynamicResource MicaWPF.Brushes.TextFillColorPrimary}"/>
                    
                    <!-- Percentage -->
                    <TextBlock Name="PercentText" Text="100%" FontSize="14" FontWeight="Medium" 
                               TextAlignment="Center" Opacity="0.4" Margin="0,-2,0,0"
                               Foreground="{DynamicResource MicaWPF.Brushes.TextFillColorSecondary}"/>
                    
                    <!-- Status label -->
                    <TextBlock Name="StatusText" Text="READY" FontSize="10" FontWeight="SemiBold" 
                               TextAlignment="Center" Opacity="0.3" Margin="0,4,0,0"
                               Foreground="{DynamicResource MicaWPF.Brushes.TextFillColorSecondary}"/>
                </StackPanel>
            </Grid>

            <!-- Buttons -->
            <Grid Margin="0,24,0,0" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Primary action (Start/Pause/Resume/Dismiss) -->
                <Border Name="PrimaryBtnBorder" Grid.Column="0" CornerRadius="24" Cursor="Hand" MouseLeftButtonDown="Action_Click"
                        MinWidth="120" Padding="24,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8B5CF6" Offset="0"/>
                            <GradientStop Color="#6366F1" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Name="ActionText" Text="▶  Start" FontSize="14" FontWeight="SemiBold" 
                               Foreground="White" TextAlignment="Center"/>
                </Border>

                <!-- Reset button -->
                <Border Name="ResetBtnBorder" Grid.Column="2" CornerRadius="24" Cursor="Hand" MouseLeftButtonDown="Reset_Click"
                        MinWidth="56" Padding="16,12" Background="#15FFFFFF" Opacity="0.6">
                    <TextBlock Text="↻" FontSize="16" TextAlignment="Center"
                               Foreground="{DynamicResource MicaWPF.Brushes.TextFillColorSecondary}"/>
                </Border>
            </Grid>
        </StackPanel>
    </Grid>
</controls:MicaWindow>
