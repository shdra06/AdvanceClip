<Window x:Class="AdvanceClip.Windows.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Notification" Height="60" Width="300"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowActivated="False" ResizeMode="NoResize"
        ShowInTaskbar="False">
    
    <Border Background="#E0111111" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="12" Padding="16,8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="4" Direction="270" />
        </Border.Effect>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <ui:SymbolIcon Symbol="Checkmark24" Foreground="#10B981" FontSize="20" Margin="0,0,12,0"/>
            <TextBlock x:Name="MessageText" Text="Link sent to Instagram" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
