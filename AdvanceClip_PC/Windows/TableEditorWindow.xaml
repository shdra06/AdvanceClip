<mica:MicaWindow x:Class="AdvanceClip.Windows.TableEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mica="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="AI Table Extractor Review" Height="600" Width="900" 
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Hybrid Advanced Table Review" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MicaWPF.Brushes.TextFillColorPrimary}" />
        <TextBlock Grid.Row="1" Text="AI Confidence heat map active. Review yellow/orange cells for optical inconsistencies before exporting into Microsoft Word CF_HTML targets." FontSize="14" Opacity="0.7" Foreground="{DynamicResource MicaWPF.Brushes.TextFillColorSecondary}" Margin="0,4,0,24" TextWrapping="Wrap" />

        <Border Grid.Row="2" Background="#0CFFFFFF" BorderBrush="#12FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid x:Name="MatrixContainer">
                    <!-- The engine natively drops the Grid array here -->
                </Grid>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="3" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="12" Height="12" Fill="#3310B981" Stroke="#10B981" StrokeThickness="1" Margin="0,0,8,0"/>
                <TextBlock Text="High Confidence" Margin="0,0,16,0" Opacity="0.8"/>
                <Ellipse Width="12" Height="12" Fill="#33EAB308" Stroke="#EAB308" StrokeThickness="1" Margin="0,0,8,0"/>
                <TextBlock Text="Medium Certainty" Margin="0,0,16,0" Opacity="0.8"/>
                <Ellipse Width="12" Height="12" Fill="#33EF4444" Stroke="#EF4444" StrokeThickness="1" Margin="0,0,8,0"/>
                <TextBlock Text="Low Confidence" Opacity="0.8"/>
            </StackPanel>

            <ui:Button Grid.Column="1" Content="Confirm &amp; Export Native Word Table" Appearance="Primary" Padding="24,12" Click="Export_Click">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Table24" />
                </ui:Button.Icon>
            </ui:Button>
        </Grid>
    </Grid>
</mica:MicaWindow>
