<Window x:Class="AdvanceClip.Windows.QuickLookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Quick Look" Height="500" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen" 
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseDoubleClick="Window_MouseDoubleClick"
        MouseMove="Window_MouseMove" Deactivated="Window_Deactivated">
    <Window.Effect>
        <DropShadowEffect Color="Black" BlurRadius="25" Opacity="0.5" Direction="270" ShadowDepth="10" />
    </Window.Effect>
    <Grid>
        <!-- Dynamic Frame -->
        <Border CornerRadius="12" Background="#801C1C1C" BorderBrush="#30FFFFFF" BorderThickness="1" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="45" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <!-- Native UI Header (Avoids Airspace Issues with Win32 WebBrowser) -->
                <Grid Grid.Row="0" Background="#90111111" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                    <TextBlock Text="Quick Look Engine - AdvanceClip" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="SemiBold" FontSize="12" IsHitTestVisible="False"/>
                    <ui:Button Click="CloseButton_Click" Appearance="Transparent" Foreground="White" HorizontalAlignment="Right" Margin="10,0,10,0" VerticalAlignment="Center">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24"/></ui:Button.Icon>
                    </ui:Button>
                </Grid>

                <Grid Grid.Row="1" Background="#20000000">
                    <!-- Image Mode -->
                    <Image x:Name="PreviewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" CacheMode="BitmapCache"/>
                    
                    <!-- Dynamic Document Mode (PDF/HTML) -->
                    <WebBrowser x:Name="WebPreview" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                    
                    <!-- Raw Text/Code/DOCX Extracted Frame -->
                    <ScrollViewer x:Name="TextPreviewScroll" Visibility="Collapsed" Background="#FF1E1E1E">
                        <TextBlock x:Name="TextPreview" Foreground="#FFD4D4D4" Margin="15" TextWrapping="Wrap" FontFamily="Consolas" FontSize="13" />
                    </ScrollViewer>
                    
                    <!-- Document Mode (Fallback when all else fails) -->
                    <StackPanel x:Name="DocumentPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                        <ui:SymbolIcon x:Name="DocIcon" Symbol="Document24" FontSize="120" Foreground="#60A5FA" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="DocTitle" Text="Document Name" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,15,0,5" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300"/>
                        <TextBlock x:Name="DocSize" Text="PDF Document - 2.4 MB" FontSize="13" Foreground="#888888" TextAlignment="Center"/>
                        <ui:Button Content="Open Native Tool" Appearance="Primary" Margin="0,20,0,0" HorizontalAlignment="Center" Click="OpenFile_Click">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Open24"/>
                            </ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>
                    
                    <!-- Instruction Overlay (fades out) -->
                    <TextBlock x:Name="HelperText" Text="Double-click to expand | Drag image natively" Foreground="#80FFFFFF" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10" FontSize="12" IsHitTestVisible="False">
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" BeginTime="0:0:3" Duration="0:0:1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
            </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
