<UserControl x:Class="AdvanceClip.Controls.AdvanceClipWidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="120"
             Background="Transparent">
    
    <Grid Name="WidgetGrid" Background="Transparent" MouseLeftButtonDown="WidgetGrid_MouseLeftButtonDown" Cursor="Hand">
        <Border Name="WidgetBorder" Background="#11FFFFFF" CornerRadius="8" Padding="6,4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="/Resources/ClipFlowIcon.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Foreground="White" FontSize="14" FontWeight="SemiBold" Text="Clip" Margin="6,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
